{
  "name": "claude-ntfy-toggle",
  "displayName": "Claude ntfy toggle",
  "description": "Status bar toggle + phone push (ntfy) when a Claude Code request finishes",
  "version": "1.2.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdurakhmanov777/claude-ping.git",
    "directory": "claude-ntfy-toggle"
  },
  "bugs": {
    "url": "https://github.com/abdurakhmanov777/claude-ping/issues"
  },
  "homepage": "https://github.com/abdurakhmanov777/claude-ping#readme",
  "keywords": [
    "claude",
    "claude code",
    "ntfy",
    "notifications",
    "push"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "scripts": {
    "lint": "eslint .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.2.0",
    "eslint": "^9.15.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "claudeNtfy.toggle",
        "title": "Claude: переключить уведомления на телефон"
      },
      {
        "command": "claudeNtfy.test",
        "title": "Claude: отправить тестовое уведомление"
      }
    ],
    "configuration": {
      "title": "Claude ntfy",
      "properties": {
        "claudeNtfy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Отправлять уведомление на телефон, когда запрос Claude Code завершился."
        },
        "claudeNtfy.topic": {
          "type": "string",
          "default": "",
          "description": "Имя вашего личного топика ntfy (на него подписан телефон в приложении ntfy). Топики публичные - придумайте непредсказуемое имя. Пока пусто, уведомления не отправляются."
        },
        "claudeNtfy.title": {
          "type": "string",
          "default": "Claude Code",
          "description": "Заголовок уведомления."
        },
        "claudeNtfy.message": {
          "type": "string",
          "default": "Запрос в Claude Code завершён",
          "description": "Текст уведомления."
        },
        "claudeNtfy.server": {
          "type": "string",
          "default": "https://ntfy.sh",
          "description": "Базовый URL сервера ntfy."
        },
        "claudeNtfy.token": {
          "type": "string",
          "default": "",
          "description": "Токен доступа ntfy (Bearer). Нужен только для защищённых топиков на своём сервере ntfy; для публичного ntfy.sh оставьте пустым."
        },
        "claudeNtfy.priority": {
          "type": "string",
          "enum": [
            "min",
            "low",
            "default",
            "high",
            "max"
          ],
          "default": "default",
          "description": "Приоритет пуша в ntfy (влияет на звук/всплытие на телефоне)."
        },
        "claudeNtfy.tags": {
          "type": "string",
          "default": "",
          "description": "Теги ntfy через запятую (напр. white_check_mark,robot). Известные имена показываются эмодзи в уведомлении. Список: https://docs.ntfy.sh/emojis/"
        },
        "claudeNtfy.click": {
          "type": "string",
          "default": "",
          "description": "URL, который откроется при тапе по уведомлению на телефоне. Пусто - без действия."
        }
      }
    }
  }
}
